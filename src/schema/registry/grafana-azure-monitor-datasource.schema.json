{
  "$schema": "../schema.json",
  "schemaVersion": "v1",
  "pluginType": "grafana-azure-monitor-datasource",
  "pluginName": "Azure Monitor",
  "docURL": "https://grafana.com/docs/grafana/latest/datasources/azure-monitor/configure",
  "fields": [
    {
      "id": "jsonData.azureAuthType",
      "key": "azureAuthType",
      "label": "Authentication type",
      "description": "Choose the type of authentication to Azure services.",
      "valueType": "string",
      "target": "jsonData",
      "required": true,
      "defaultValue": "clientsecret",
      "validations": [
        {
          "type": "allowedValues",
          "values": [
            "currentuser",
            "clientsecret",
            "clientcertificate",
            "msi",
            "workloadidentity",
            "ad-password"
          ]
        }
      ],
      "ui": {
        "component": "select",
        "options": [
          {
            "label": "Current User",
            "value": "currentuser"
          },
          {
            "label": "App Registration (Client Secret)",
            "value": "clientsecret"
          },
          {
            "label": "App Registration (Client Certificate)",
            "value": "clientcertificate"
          },
          {
            "label": "Managed Identity",
            "value": "msi"
          },
          {
            "label": "Workload Identity",
            "value": "workloadidentity"
          },
          {
            "label": "AD Password",
            "value": "ad-password"
          }
        ]
      }
    },
    {
      "id": "jsonData.cloudName",
      "key": "cloudName",
      "label": "Azure Cloud",
      "description": "Azure cloud environment.",
      "valueType": "string",
      "target": "jsonData",
      "defaultValue": "azuremonitor",
      "dependsOn": "jsonData.azureAuthType == 'clientsecret' || jsonData.azureAuthType == 'clientcertificate'",
      "ui": {
        "component": "select",
        "options": [
          {
            "label": "Azure",
            "value": "azuremonitor"
          },
          {
            "label": "Azure China",
            "value": "chinaazuremonitor"
          },
          {
            "label": "Azure US Government",
            "value": "govazuremonitor"
          }
        ]
      }
    },
    {
      "id": "jsonData.tenantId",
      "key": "tenantId",
      "label": "Directory (tenant) ID",
      "description": "Azure AD directory (tenant) ID.",
      "valueType": "string",
      "target": "jsonData",
      "dependsOn": "jsonData.azureAuthType == 'clientsecret' || jsonData.azureAuthType == 'clientcertificate'",
      "requiredWhen": "jsonData.azureAuthType == 'clientsecret'",
      "ui": {
        "placeholder": "XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX"
      }
    },
    {
      "id": "jsonData.clientId",
      "key": "clientId",
      "label": "Application (client) ID",
      "description": "Azure AD application (client) ID.",
      "valueType": "string",
      "target": "jsonData",
      "dependsOn": "jsonData.azureAuthType == 'clientsecret' || jsonData.azureAuthType == 'clientcertificate'",
      "requiredWhen": "jsonData.azureAuthType == 'clientsecret'",
      "ui": {
        "placeholder": "XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX"
      }
    },
    {
      "id": "secureJsonData.azureClientSecret",
      "key": "azureClientSecret",
      "label": "Client Secret",
      "description": "Azure AD application client secret.",
      "valueType": "string",
      "target": "secureJsonData",
      "semanticType": "token",
      "dependsOn": "jsonData.azureAuthType == 'clientsecret'",
      "requiredWhen": "jsonData.azureAuthType == 'clientsecret'",
      "ui": {
        "placeholder": "XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX"
      }
    },
    {
      "id": "jsonData.azureCredentials.certificateFormat",
      "key": "certificateFormat",
      "label": "Format",
      "description": "Choose the format of the certificate (PEM certificates should be in plain text PEM format, PFX certificates should be in base64 encoded PFX format).",
      "valueType": "string",
      "target": "jsonData",
      "dependsOn": "jsonData.azureAuthType == 'clientcertificate'",
      "ui": {
        "component": "select",
        "options": [
          {
            "label": "PEM",
            "value": "pem"
          },
          {
            "label": "PFX",
            "value": "pfx"
          }
        ]
      }
    },
    {
      "id": "secureJsonData.clientCertificate",
      "key": "clientCertificate",
      "label": "Client Certificate",
      "description": "Client certificate for Azure AD authentication.",
      "valueType": "string",
      "target": "secureJsonData",
      "dependsOn": "jsonData.azureAuthType == 'clientcertificate'",
      "ui": {
        "component": "textarea",
        "rows": 7,
        "placeholder": "-----BEGIN CERTIFICATE-----"
      }
    },
    {
      "id": "secureJsonData.privateKey",
      "key": "privateKey",
      "label": "Private Key",
      "description": "Private key for PEM certificate authentication.",
      "valueType": "string",
      "target": "secureJsonData",
      "semanticType": "token",
      "dependsOn": "jsonData.azureAuthType == 'clientcertificate'",
      "ui": {
        "component": "textarea",
        "rows": 7,
        "placeholder": "-----BEGIN PRIVATE KEY-----"
      }
    },
    {
      "id": "secureJsonData.certificatePassword",
      "key": "certificatePassword",
      "label": "Certificate Password",
      "description": "Password for the PFX certificate.",
      "valueType": "string",
      "target": "secureJsonData",
      "semanticType": "password",
      "dependsOn": "jsonData.azureAuthType == 'clientcertificate'"
    },
    {
      "id": "jsonData.azureCredentials",
      "key": "azureCredentials",
      "label": "Azure Credentials",
      "description": "Azure credentials configuration object (managed by azure-sdk).",
      "valueType": "object",
      "target": "jsonData",
      "tags": [
        "managed-by:jsonData.azureAuthType"
      ]
    },
    {
      "id": "jsonData.oauthPassThru",
      "key": "oauthPassThru",
      "label": "Forward OAuth Identity",
      "description": "Forward the logged-in user's OAuth token to the data source.",
      "valueType": "boolean",
      "target": "jsonData",
      "tags": [
        "managed-by:jsonData.azureAuthType"
      ]
    },
    {
      "id": "jsonData.subscriptionId",
      "key": "subscriptionId",
      "label": "Default Subscription",
      "description": "Default Azure subscription ID.",
      "valueType": "string",
      "target": "jsonData"
    },
    {
      "id": "jsonData.basicLogsEnabled",
      "key": "basicLogsEnabled",
      "label": "Enable Basic Logs",
      "description": "Enabling this feature incurs Azure Monitor per-query costs on dashboard panels that query tables configured for Basic Logs.",
      "valueType": "boolean",
      "target": "jsonData",
      "ui": {
        "component": "switch"
      }
    },
    {
      "id": "jsonData.enableSecureSocksProxy",
      "key": "enableSecureSocksProxy",
      "label": "Enable Secure Socks Proxy",
      "description": "Enable proxying the datasource connection through the secure socks proxy to a different network.",
      "valueType": "boolean",
      "target": "jsonData",
      "ui": {
        "component": "switch"
      }
    },
    {
      "id": "jsonData.timeout",
      "key": "timeout",
      "label": "Timeout (seconds)",
      "description": "HTTP request timeout in seconds.",
      "valueType": "number",
      "target": "jsonData"
    },
    {
      "id": "jsonData.keepCookies",
      "key": "keepCookies",
      "label": "Allowed Cookies",
      "description": "Cookie names to forward to Azure.",
      "valueType": "array",
      "target": "jsonData",
      "item": {
        "valueType": "string"
      }
    }
  ],
  "groups": [
    {
      "id": "auth",
      "title": "Authentication",
      "description": "Choose the type of authentication to Azure services.",
      "fieldRefs": [
        "jsonData.azureAuthType",
        "jsonData.cloudName",
        "jsonData.tenantId",
        "jsonData.clientId",
        "secureJsonData.azureClientSecret",
        "jsonData.azureCredentials.certificateFormat",
        "secureJsonData.clientCertificate",
        "secureJsonData.privateKey",
        "secureJsonData.certificatePassword"
      ]
    },
    {
      "id": "advanced",
      "title": "Additional settings",
      "description": "Additional settings are optional settings that can be configured for more control over your data source.",
      "fieldRefs": [
        "jsonData.subscriptionId",
        "jsonData.basicLogsEnabled",
        "jsonData.timeout",
        "jsonData.keepCookies",
        "jsonData.enableSecureSocksProxy"
      ]
    }
  ]
}
