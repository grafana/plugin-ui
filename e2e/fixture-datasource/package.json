{
  "name": "grafana-pluginuifixture-datasource",
  "version": "1.0.0",
  "description": "Fixture data source plugin that renders @grafana/plugin-ui components for e2e validation across Grafana versions.",
  "private": true,
  "scripts": {
    "build": "webpack --config webpack.config.js --env production",
    "dev": "webpack --config webpack.config.js --env development --watch",
    "typecheck": "tsc --noEmit",
    "check-coverage": "node scripts/check-coverage.mjs"
  },
  "author": "Grafana Labs",
  "license": "Apache-2.0",
  "dependencies": {
    "@emotion/css": "^11.13.5",
    "@grafana/data": "^13.0.0",
    "@grafana/plugin-ui": "file:../../plugin-ui.tgz",
    "@grafana/runtime": "^13.0.0",
    "@grafana/schema": "^13.0.0",
    "@grafana/ui": "^13.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@swc/core": "^1.7.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "copy-webpack-plugin": "^14.0.0",
    "swc-loader": "^0.2.6",
    "typescript": "^5.5.0",
    "webpack": "^5.94.0",
    "webpack-cli": "^5.1.4"
  }
}
