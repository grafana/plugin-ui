    {
      "id": "jsonData.serviceEndpoint",
      "key": "serviceEndpoint",
      "label": "Service Endpoint",
      "description": "Custom BigQuery API endpoint URL.",
      "valueType": "string",
      "target": "jsonData",
      "ui": {
        "component": "input",
        "placeholder": "Optional, example https://bigquery.googleapis.com/bigquery/v2/"
      }
    },
    {
      "id": "jsonData.MaxBytesBilled",
      "key": "MaxBytesBilled",
      "label": "Max Bytes Billed",
      "description": "Limits the bytes billed per query. Queries exceeding this limit will fail.",
      "valueType": "number",
      "target": "jsonData",
      "ui": {
        "component": "input",
        "placeholder": "Optional, example 5242880"
      }
    },
    {
      "id": "jsonData.queryPriority",
      "key": "queryPriority",
      "label": "Query Priority",
      "description": "BigQuery query priority.",
      "valueType": "string",
      "target": "jsonData",
      "ui": {
        "component": "select",
        "options": [
          {
            "label": "Interactive",
            "value": "INTERACTIVE"
          },
          {
            "label": "Batch",
            "value": "BATCH"
          }
        ]
      }
    },
    {
      "id": "jsonData.flatRateProject",
      "key": "flatRateProject",
      "label": "Flat Rate Project",
      "description": "Project used for flat-rate billing reservation.",
      "valueType": "string",
      "target": "jsonData"
    },
    {
      "id": "jsonData.enableSecureSocksProxy",
      "key": "enableSecureSocksProxy",
      "label": "Secure Socks Proxy",
