      "target": "jsonData",
      "section": "logs",
      "ui": {
        "component": "input",
        "placeholder": "filter_time_column"
      },
      "overrides": [
        {
          "when": "jsonData.logs.otelEnabled == true",
          "readOnly": true,
          "description": "Set by OTel schema version",
          "placeholder": "TimestampTime"
        }
      ]
    },
    {
      "id": "jsonData.logs.timeColumn",
      "key": "timeColumn",
