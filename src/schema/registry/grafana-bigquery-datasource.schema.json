{
  "$schema": "../schema.json",
  "schemaVersion": "v1",
  "pluginType": "grafana-bigquery-datasource",
  "pluginName": "Google BigQuery",
  "docURL": "https://grafana.com/grafana/plugins/grafana-bigquery-datasource/",
  "fields": [
    {
      "id": "jsonData.authenticationType",
      "key": "authenticationType",
      "label": "Authentication type",
      "description": "Google Cloud authentication mechanism.",
      "valueType": "string",
      "target": "jsonData",
      "required": true,
      "defaultValue": "jwt",
      "validations": [
        {
          "type": "allowedValues",
          "values": [
            "jwt",
            "gce",
            "forwardOAuthIdentity"
          ]
        }
      ],
      "ui": {
        "component": "select",
        "options": [
          {
            "label": "Google JWT File",
            "value": "jwt"
          },
          {
            "label": "GCE Default Service Account",
            "value": "gce"
          },
          {
            "label": "Forward OAuth Identity",
            "value": "forwardOAuthIdentity"
          }
        ]
      },
      "effects": [
        {
          "when": "value == 'jwt'",
          "set": {
            "virtual.jwtUpload": "upload",
            "jsonData.oauthPassThru": false
          }
        },
        {
          "when": "value == 'gce'",
          "set": {
            "virtual.jwtUpload": "manual",
            "jsonData.oauthPassThru": false
          }
        },
        {
          "when": "value == 'forwardOAuthIdentity'",
          "set": {
            "virtual.jwtUpload": "",
            "jsonData.oauthPassThru": true
          }
        }
      ]
    },
    {
      "id": "virtual.jwtUpload",
      "key": "jwtUpload",
      "label": "JWT Token",
      "description": "Upload or paste a Google service account JSON key file. The file contents are parsed and the relevant fields are populated automatically.",
      "valueType": "string",
      "kind": "virtual",
      "defaultValue": "upload",
      "dependsOn": "jsonData.authenticationType == 'jwt'",
      "storage": {
        "type": "computed",
        "read": "jsonData.clientEmail ? 'manual' : 'upload'"
      },
      "ui": {
        "component": "fileUpload",
        "accept": [
          ".json"
        ],
        "placeholder": "Paste Google JWT token here",
        "fileMapping": {
          "project_id": "jsonData.defaultProject",
          "client_email": "jsonData.clientEmail",
          "token_uri": "jsonData.tokenUri",
          "private_key": "secureJsonData.privateKey"
        }
      }
    },
    {
      "id": "jsonData.defaultProject",
      "key": "defaultProject",
      "label": "Project ID",
      "description": "GCP project ID. In JWT mode, auto-filled from the service account JSON.",
      "valueType": "string",
      "target": "jsonData",
      "dependsOn": "virtual.jwtUpload == 'manual'"
    },
    {
      "id": "jsonData.clientEmail",
      "key": "clientEmail",
      "label": "Client Email",
      "description": "Service account email address for JWT authentication.",
      "valueType": "string",
      "target": "jsonData",
      "dependsOn": "virtual.jwtUpload == 'manual'"
    },
    {
      "id": "jsonData.tokenUri",
      "key": "tokenUri",
      "label": "Token URI",
      "description": "OAuth2 token endpoint URI.",
      "valueType": "string",
      "target": "jsonData",
      "defaultValue": "https://oauth2.googleapis.com/token",
      "dependsOn": "virtual.jwtUpload == 'manual'"
    },
    {
      "id": "virtual.privateKeyMode",
      "key": "privateKeyMode",
      "label": "Private key",
      "valueType": "string",
      "kind": "virtual",
      "defaultValue": "paste",
      "dependsOn": "virtual.jwtUpload == 'manual'",
      "storage": {
        "type": "computed",
        "read": "jsonData.privateKeyPath ? 'path' : 'paste'"
      },
      "ui": {
        "component": "radio",
        "options": [
          {
            "label": "Paste private key",
            "value": "paste"
          },
          {
            "label": "Provide path to private key file",
            "value": "path"
          }
        ]
      }
    },
    {
      "id": "secureJsonData.privateKey",
      "key": "privateKey",
      "label": "Private Key",
      "description": "Service account private key for JWT authentication.",
      "valueType": "string",
      "semanticType": "token",
      "target": "secureJsonData",
      "dependsOn": "virtual.privateKeyMode == 'paste'"
    },
    {
      "id": "jsonData.privateKeyPath",
      "key": "privateKeyPath",
      "label": "Private Key Path",
      "description": "Path to a local private key file on the Grafana server. Not supported in hosted environments.",
      "valueType": "string",
      "target": "jsonData",
      "dependsOn": "virtual.privateKeyMode == 'path'",
      "ui": {
        "component": "input",
        "placeholder": "File location of your private key (e.g. /etc/secrets/bigquery.pem)"
      }
    },
    {
      "id": "jsonData.defaultProjectNonJwt",
      "key": "defaultProject",
      "label": "Default Project",
      "description": "Default GCP project for queries.",
      "valueType": "string",
      "target": "jsonData",
      "dependsOn": "jsonData.authenticationType != 'jwt'"
    },
    {
      "id": "jsonData.oauthPassThru",
      "key": "oauthPassThru",
      "label": "Forward OAuth Identity",
      "description": "Forward the user's OAuth token to BigQuery.",
      "valueType": "boolean",
      "target": "jsonData",
      "tags": [
        "managed-by:jsonData.authenticationType"
      ]
    },
    {
      "id": "jsonData.usingImpersonation",
      "key": "usingImpersonation",
      "label": "Enable service account impersonation",
      "description": "Read more about service account impersonation.",
      "valueType": "boolean",
      "target": "jsonData",
      "dependsOn": "jsonData.authenticationType != 'forwardOAuthIdentity'",
      "ui": {
        "component": "switch"
      }
    },
    {
      "id": "jsonData.serviceAccountToImpersonate",
      "key": "serviceAccountToImpersonate",
      "label": "Service account to impersonate",
      "description": "Email of the service account to impersonate.",
      "valueType": "string",
      "target": "jsonData",
      "dependsOn": "jsonData.authenticationType != 'forwardOAuthIdentity' && jsonData.usingImpersonation == true"
    },
    {
