{
  "$schema": "../schema.json",
  "schemaVersion": "v1",
  "pluginType": "grafana-pyroscope-datasource",
  "pluginName": "Pyroscope",
  "docURL": "https://grafana.com/docs/grafana/latest/datasources/pyroscope/",
  "fields": [
    {
      "id": "jsonData.minStep",
      "key": "minStep",
      "label": "Minimal step",
      "description": "Minimal step used for metric query. Should be the same or higher as the scrape interval setting in the Pyroscope database.",
      "valueType": "string",
      "semanticType": "duration",
      "target": "jsonData",
      "ui": {
        "component": "input",
        "placeholder": "15s"
      }
    }
  ],
  "groups": [
    {
      "id": "querying",
      "title": "Querying",
      "fieldRefs": [
        "jsonData.minStep"
      ]
    }
  ]
}
