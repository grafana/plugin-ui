{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                "dist/**",
                "compiled/**"
            ]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "test": {
            "cache": false,
            "persistent": true
        },
        "test:ci": {
            "dependsOn": [
                "^build"
            ]
        },
        "lint": {
            "dependsOn": [
                "^build"
            ]
        },
        "lint:fix": {
            "cache": false
        },
        "typecheck": {
            "dependsOn": [
                "^build"
            ]
        },
        "clean": {
            "cache": false
        },
        "storybook": {
            "cache": false,
            "persistent": true
        },
        "storybook:build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                "storybook-static/**"
            ]
        },
        "spellcheck": {},
        "verify-types": {
            "dependsOn": [
                "build"
            ]
        },
        "verify-packagejson": {}
    }
}
