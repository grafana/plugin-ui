{
  "$schema": "../schema.json",
  "schemaVersion": "v1",
  "pluginType": "yesoreyeram-infinity-datasource",
  "pluginName": "Infinity",
  "docURL": "https://grafana.com/grafana/plugins/yesoreyeram-infinity-datasource/",
  "fields": [
    {
      "id": "root.url",
      "key": "url",
      "label": "Base URL",
      "description": "Base URL of the query. Leave blank if you want to handle it in the query editor.",
      "valueType": "string",
      "semanticType": "url",
      "target": "root",
      "tags": [
        "pinned"
      ],
      "ui": {
        "component": "input",
        "placeholder": "Leave blank and you can specify full URL in the query."
      }
    },
    {
      "id": "jsonData.auth_method",
      "key": "auth_method",
      "label": "Authentication method",
      "description": "Authentication method for requests.",
      "valueType": "string",
      "target": "jsonData",
      "defaultValue": "none",
      "validations": [
        {
          "type": "allowedValues",
          "values": [
            "none",
            "basicAuth",
            "apiKey",
            "bearerToken",
            "oauthPassThru",
            "digestAuth",
            "oauth2",
            "aws",
            "azureBlob"
          ]
        }
      ],
      "ui": {
        "component": "select",
        "options": [
          {
            "label": "No Auth",
            "value": "none"
          },
          {
            "label": "Basic Authentication",
            "value": "basicAuth"
          },
          {
            "label": "API Key",
            "value": "apiKey"
          },
          {
            "label": "Bearer Token",
            "value": "bearerToken"
          },
          {
            "label": "Forward OAuth",
            "value": "oauthPassThru"
          },
          {
            "label": "Digest Auth",
            "value": "digestAuth"
          },
          {
            "label": "OAuth2",
            "value": "oauth2"
          },
          {
            "label": "AWS",
            "value": "aws"
          },
          {
            "label": "Azure Blob",
            "value": "azureBlob"
          }
        ]
      },
      "effects": [
        {
          "when": "value == 'oauthPassThru'",
          "set": {
            "jsonData.oauthPassThru": true
          }
        },
        {
          "when": "value != 'oauthPassThru'",
          "set": {
            "jsonData.oauthPassThru": false
          }
        },
        {
          "when": "value == 'basicAuth'",
          "set": {
            "root.basicAuth": true
          }
        },
        {
          "when": "value != 'basicAuth'",
          "set": {
            "root.basicAuth": false
          }
        }
      ]
    },
    {
      "id": "root.basicAuth",
      "key": "basicAuth",
      "label": "Basic Auth",
      "valueType": "boolean",
      "target": "root",
      "defaultValue": false,
      "tags": [
        "managed-by:jsonData.auth_method"
      ],
      "kind": "virtual"
    },
    {
      "id": "root.basicAuthUser",
      "key": "basicAuthUser",
      "label": "User Name",
      "description": "Username for authentication.",
      "valueType": "string",
      "target": "root",
      "dependsOn": "jsonData.auth_method == 'basicAuth'",
      "requiredWhen": "jsonData.auth_method == 'basicAuth'",
      "ui": {
        "component": "input",
        "placeholder": "username"
      }
    },
    {
      "id": "secureJsonData.basicAuthPassword",
      "key": "basicAuthPassword",
      "label": "Password",
      "description": "Password for authentication.",
      "valueType": "string",
      "semanticType": "password",
      "target": "secureJsonData",
      "dependsOn": "jsonData.auth_method == 'basicAuth'",
      "requiredWhen": "jsonData.auth_method == 'basicAuth'"
    },
    {
      "id": "root.digestAuthUser",
      "key": "basicAuthUser",
      "label": "User Name",
      "description": "Username for digest authentication.",
      "valueType": "string",
      "target": "root",
      "dependsOn": "jsonData.auth_method == 'digestAuth'",
      "requiredWhen": "jsonData.auth_method == 'digestAuth'",
      "ui": {
        "component": "input",
        "placeholder": "username"
      }
    },
    {
      "id": "secureJsonData.basicAuthPasswordDigest",
      "key": "basicAuthPassword",
      "label": "Password",
      "description": "Password for digest authentication.",
      "valueType": "string",
      "semanticType": "password",
      "target": "secureJsonData",
      "dependsOn": "jsonData.auth_method == 'digestAuth'",
      "requiredWhen": "jsonData.auth_method == 'digestAuth'"
    },
    {
      "id": "jsonData.apiKeyKey",
      "key": "apiKeyKey",
      "label": "Key",
      "description": "API key name.",
      "valueType": "string",
      "target": "jsonData",
      "dependsOn": "jsonData.auth_method == 'apiKey'",
      "requiredWhen": "jsonData.auth_method == 'apiKey'",
      "ui": {
        "component": "input",
        "placeholder": "api key key"
      }
    },
    {
      "id": "secureJsonData.apiKeyValue",
      "key": "apiKeyValue",
      "label": "Value",
      "description": "API key value.",
      "valueType": "string",
      "semanticType": "token",
      "target": "secureJsonData",
      "dependsOn": "jsonData.auth_method == 'apiKey'",
      "requiredWhen": "jsonData.auth_method == 'apiKey'"
    },
    {
      "id": "jsonData.apiKeyType",
      "key": "apiKeyType",
      "label": "Add to",
      "description": "Add api key to header or query params.",
      "valueType": "string",
      "target": "jsonData",
      "defaultValue": "header",
      "dependsOn": "jsonData.auth_method == 'apiKey'",
      "validations": [
        {
          "type": "allowedValues",
          "values": [
            "header",
            "query"
          ]
        }
      ],
      "ui": {
        "component": "radio",
        "options": [
          {
            "label": "Header",
            "value": "header"
          },
          {
            "label": "Query Param",
            "value": "query"
          }
        ]
      }
    },
    {
      "id": "secureJsonData.bearerToken",
      "key": "bearerToken",
      "label": "Bearer Token",
      "description": "Bearer token for authentication.",
      "valueType": "string",
      "semanticType": "token",
      "target": "secureJsonData",
      "dependsOn": "jsonData.auth_method == 'bearerToken'",
      "requiredWhen": "jsonData.auth_method == 'bearerToken'"
    },
    {
      "id": "jsonData.oauth2.oauth2_type",
      "key": "oauth2_type",
      "label": "Grant type",
      "description": "OAuth2 grant type.",
      "valueType": "string",
      "target": "jsonData",
      "section": "oauth2",
      "defaultValue": "client_credentials",
      "dependsOn": "jsonData.auth_method == 'oauth2'",
      "validations": [
        {
          "type": "allowedValues",
          "values": [
            "client_credentials",
            "jwt"
          ]
        }
      ],
      "ui": {
        "component": "radio",
        "options": [
          {
            "label": "Client Credentials",
            "value": "client_credentials"
          },
          {
            "label": "JWT",
            "value": "jwt"
          }
        ]
      }
    },
    {
      "id": "jsonData.oauth2.authStyle",
      "key": "authStyle",
      "label": "Auth Style",
      "description": "AuthStyleAutoDetect means to auto-detect which authentication style the provider wants. AuthStyleInParams sends the client_id and client_secret in the POST body. AuthStyleInHeader sends them using HTTP Basic Authorization.",
      "valueType": "number",
      "target": "jsonData",
      "section": "oauth2",
      "defaultValue": 0,
      "dependsOn": "jsonData.oauth2.oauth2_type == 'client_credentials'",
      "ui": {
        "component": "radio",
        "options": [
          {
            "label": "Auto",
            "value": "0"
          },
          {
            "label": "In Params",
            "value": "1"
          },
          {
            "label": "In Header",
            "value": "2"
          }
        ]
      }
    },
    {
      "id": "jsonData.oauth2.client_id",
      "key": "client_id",
      "label": "Client ID",
      "description": "OAuth2 Client ID.",
      "valueType": "string",
      "target": "jsonData",
      "section": "oauth2",
      "dependsOn": "jsonData.oauth2.oauth2_type == 'client_credentials'",
      "requiredWhen": "jsonData.oauth2.oauth2_type == 'client_credentials'",
      "ui": {
        "component": "input",
        "placeholder": "Client ID"
      }
    },
    {
      "id": "secureJsonData.oauth2ClientSecret",
      "key": "oauth2ClientSecret",
      "label": "Client Secret",
      "description": "OAuth2 client secret.",
      "valueType": "string",
      "semanticType": "token",
      "target": "secureJsonData",
      "dependsOn": "jsonData.oauth2.oauth2_type == 'client_credentials'",
      "requiredWhen": "jsonData.oauth2.oauth2_type == 'client_credentials'"
    },
    {
      "id": "jsonData.oauth2.email",
      "key": "email",
      "label": "Email",
      "description": "OAuth client identifier used when communicating with the configured OAuth provider.",
      "valueType": "string",
      "target": "jsonData",
      "section": "oauth2",
      "dependsOn": "jsonData.oauth2.oauth2_type == 'jwt'",
      "requiredWhen": "jsonData.oauth2.oauth2_type == 'jwt'",
      "ui": {
        "component": "input",
        "placeholder": "email"
      }
    },
    {
      "id": "jsonData.oauth2.private_key_id",
      "key": "private_key_id",
      "label": "Private Key ID",
      "description": "A hint indicating which key to use.",
      "valueType": "string",
      "target": "jsonData",
      "section": "oauth2",
      "dependsOn": "jsonData.oauth2.oauth2_type == 'jwt'",
      "ui": {
        "component": "input",
        "placeholder": "(optional) private key identifier"
      }
    },
    {
      "id": "secureJsonData.oauth2JWTPrivateKey",
      "key": "oauth2JWTPrivateKey",
      "label": "Private Key",
      "description": "RSA private key or PEM file contents for OAuth2 JWT.",
      "valueType": "string",
      "semanticType": "token",
      "target": "secureJsonData",
      "dependsOn": "jsonData.oauth2.oauth2_type == 'jwt'",
      "requiredWhen": "jsonData.oauth2.oauth2_type == 'jwt'"
    },
    {
      "id": "jsonData.oauth2.token_url",
      "key": "token_url",
      "label": "Token URL",
      "description": "OAuth2 token endpoint URL.",
      "valueType": "string",
      "semanticType": "url",
      "target": "jsonData",
      "section": "oauth2",
      "dependsOn": "jsonData.auth_method == 'oauth2'",
      "requiredWhen": "jsonData.auth_method == 'oauth2'",
      "ui": {
        "component": "input",
        "placeholder": "Token URL"
      }
    },
    {
      "id": "jsonData.oauth2.subject",
      "key": "subject",
      "label": "Subject",
      "description": "The user to impersonate.",
      "valueType": "string",
      "target": "jsonData",
      "section": "oauth2",
      "dependsOn": "jsonData.oauth2.oauth2_type == 'jwt'",
      "ui": {
        "component": "input",
        "placeholder": "(optional) Subject"
      }
    },
    {
      "id": "jsonData.oauth2.scopes",
      "key": "scopes",
      "label": "Scopes",
      "description": "Comma-separated list of requested permission scopes.",
      "valueType": "array",
      "target": "jsonData",
      "section": "oauth2",
      "dependsOn": "jsonData.auth_method == 'oauth2'",
      "item": {
        "valueType": "string"
      }
    },
    {
      "id": "jsonData.oauth2EndpointParams",
      "key": "oauth2EndpointParams",
      "label": "Endpoint Params",
      "description": "Additional parameters for requests to the token endpoint.",
      "valueType": "array",
      "target": "jsonData",
      "dependsOn": "jsonData.oauth2.oauth2_type == 'client_credentials'",
      "storage": {
        "type": "indexedPair",
        "key": {
          "target": "jsonData",
          "pattern": "oauth2EndPointParamsName{index}"
        },
        "value": {
          "target": "secureJsonData",
          "pattern": "oauth2EndPointParamsValue{index}"
        },
        "startIndex": 1
      },
      "item": {
        "valueType": "string"
      }
    },
    {
      "id": "jsonData.oauth2.authHeader",
      "key": "authHeader",
      "label": "Custom Token Header",
      "description": "Once the token is retrieved, it will be sent in subsequent requests with this header key. Defaults to Authorization.",
      "valueType": "string",
      "target": "jsonData",
      "section": "oauth2",
      "dependsOn": "jsonData.auth_method == 'oauth2'",
      "ui": {
        "component": "input",
        "placeholder": "Authorization"
      }
    },
    {
      "id": "jsonData.oauth2.tokenTemplate",
      "key": "tokenTemplate",
      "label": "Custom Token Template",
      "description": "Token template allows you to customize the token value. String ${__oauth2.access_token} will be replaced with the actual access token.",
      "valueType": "string",
      "target": "jsonData",
      "section": "oauth2",
      "dependsOn": "jsonData.auth_method == 'oauth2'",
      "ui": {
        "component": "input",
        "placeholder": "Bearer ${__oauth2.access_token}"
      }
    },
    {
      "id": "jsonData.oauth2TokenHeaders",
      "key": "oauth2TokenHeaders",
      "label": "Token Request Headers",
      "description": "Custom headers sent with token requests.",
      "valueType": "array",
      "target": "jsonData",
      "dependsOn": "jsonData.auth_method == 'oauth2'",
      "storage": {
        "type": "indexedPair",
        "key": {
          "target": "jsonData",
          "pattern": "oauth2TokenHeadersName{index}"
        },
        "value": {
          "target": "secureJsonData",
          "pattern": "oauth2TokenHeadersValue{index}"
        },
        "startIndex": 1
      },
      "item": {
        "valueType": "string"
      }
    },
    {
      "id": "jsonData.aws.region",
      "key": "region",
      "label": "Region",
      "description": "AWS region.",
      "valueType": "string",
      "target": "jsonData",
      "section": "aws",
      "dependsOn": "jsonData.auth_method == 'aws'",
      "ui": {
        "component": "input",
        "placeholder": "us-east-1"
      }
    },
    {
      "id": "jsonData.aws.service",
      "key": "service",
      "label": "Service",
      "description": "AWS service name for signing requests.",
      "valueType": "string",
      "target": "jsonData",
      "section": "aws",
      "dependsOn": "jsonData.auth_method == 'aws'",
      "ui": {
        "component": "input",
        "placeholder": "aps"
      }
    },
    {
      "id": "secureJsonData.awsAccessKey",
      "key": "awsAccessKey",
      "label": "Access Key",
      "description": "AWS access key.",
      "valueType": "string",
      "semanticType": "token",
      "target": "secureJsonData",
      "dependsOn": "jsonData.auth_method == 'aws'",
      "requiredWhen": "jsonData.auth_method == 'aws'"
    },
    {
      "id": "secureJsonData.awsSecretKey",
      "key": "awsSecretKey",
      "label": "Secret Key",
      "description": "AWS secret key.",
      "valueType": "string",
      "semanticType": "token",
      "target": "secureJsonData",
      "dependsOn": "jsonData.auth_method == 'aws'",
      "requiredWhen": "jsonData.auth_method == 'aws'"
    },
    {
      "id": "jsonData.azureBlobCloudType",
      "key": "azureBlobCloudType",
      "label": "Azure cloud",
      "description": "Azure cloud type.",
      "valueType": "string",
      "target": "jsonData",
      "defaultValue": "azureblob",
      "dependsOn": "jsonData.auth_method == 'azureBlob'",
      "validations": [
        {
          "type": "allowedValues",
          "values": [
            "azureblob",
            "azureblobchina",
            "azureblobgov"
          ]
        }
      ],
      "ui": {
        "component": "select",
        "options": [
          {
            "label": "Azure Global",
            "value": "azureblob"
          },
          {
            "label": "Azure China",
            "value": "azureblobchina"
          },
          {
            "label": "Azure Government",
            "value": "azureblobgov"
          }
        ]
      }
    },
    {
      "id": "jsonData.azureBlobAccountName",
      "key": "azureBlobAccountName",
      "label": "Storage account name",
      "description": "Azure blob storage account name.",
      "valueType": "string",
      "target": "jsonData",
      "dependsOn": "jsonData.auth_method == 'azureBlob'",
      "requiredWhen": "jsonData.auth_method == 'azureBlob'",
      "ui": {
        "component": "input",
        "placeholder": "Azure blob storage account name"
      }
    },
    {
      "id": "secureJsonData.azureBlobAccountKey",
      "key": "azureBlobAccountKey",
      "label": "Storage account key",
      "description": "Azure blob storage account key.",
      "valueType": "string",
      "semanticType": "token",
      "target": "secureJsonData",
      "dependsOn": "jsonData.auth_method == 'azureBlob'",
      "requiredWhen": "jsonData.auth_method == 'azureBlob'"
    },
    {
      "id": "jsonData.oauthPassThru",
      "key": "oauthPassThru",
      "label": "Forward OAuth Identity",
      "description": "Forward the user's OAuth token.",
      "valueType": "boolean",
      "target": "jsonData",
      "defaultValue": false,
      "tags": [
        "managed-by:jsonData.auth_method"
      ],
      "ui": {
        "component": "switch"
      }
    },
    {
      "id": "jsonData.allowedHosts",
      "key": "allowedHosts",
      "label": "Allowed hosts",
      "description": "List of allowed hosts for outgoing requests. Leave empty to allow all.",
      "valueType": "array",
      "target": "jsonData",
      "tags": [
        "pinned"
      ],
      "item": {
        "valueType": "string"
      }
    },
    {
      "id": "jsonData.httpHeaders",
      "key": "httpHeaders",
      "label": "Custom HTTP Headers",
      "description": "Custom HTTP headers for all requests.",
      "valueType": "array",
      "target": "jsonData",
      "storage": {
        "type": "indexedPair",
        "key": {
          "target": "jsonData",
          "pattern": "httpHeaderName{index}"
        },
        "value": {
          "target": "secureJsonData",
          "pattern": "httpHeaderValue{index}"
        },
        "startIndex": 1
      },
      "item": {
        "valueType": "string"
      }
    },
    {
      "id": "jsonData.secureQueryParams",
      "key": "secureQueryParams",
      "label": "URL Query Params",
      "description": "Secure URL query parameters for all requests.",
      "valueType": "array",
      "target": "jsonData",
      "storage": {
        "type": "indexedPair",
        "key": {
          "target": "jsonData",
          "pattern": "secureQueryName{index}"
        },
        "value": {
          "target": "secureJsonData",
          "pattern": "secureQueryValue{index}"
        },
        "startIndex": 1
      },
      "item": {
        "valueType": "string"
      }
    },
    {
      "id": "jsonData.ignoreStatusCodeCheck",
      "key": "ignoreStatusCodeCheck",
      "label": "Ignore status code check",
      "description": "When enabled, the datasource will process response body even for HTTP error status codes (4xx, 5xx). Useful for APIs that return data in error responses.",
      "valueType": "boolean",
      "target": "jsonData",
      "ui": {
        "component": "switch"
      }
    },
    {
      "id": "jsonData.allowDangerousHTTPMethods",
      "key": "allowDangerousHTTPMethods",
      "label": "Allow dangerous HTTP methods",
      "description": "When enabled, allows HTTP methods like PUT, DELETE, PATCH in queries.",
      "valueType": "boolean",
      "target": "jsonData",
      "ui": {
        "component": "switch"
      }
    },
    {
      "id": "jsonData.pathEncodedUrlsEnabled",
      "key": "pathEncodedUrlsEnabled",
      "label": "Path encoded URLs",
      "description": "Allow path-encoded URLs.",
      "valueType": "boolean",
      "target": "jsonData",
      "ui": {
        "component": "switch"
      }
    },
    {
      "id": "jsonData.keepCookies",
      "key": "keepCookies",
      "label": "Allowed cookies",
      "description": "Cookies to forward to the data source.",
      "valueType": "array",
      "target": "jsonData",
      "item": {
        "valueType": "string"
      }
    },
    {
      "id": "jsonData.timeoutInSeconds",
      "key": "timeoutInSeconds",
      "label": "Timeout in seconds",
      "description": "HTTP request timeout in seconds.",
      "valueType": "number",
      "target": "jsonData",
      "defaultValue": 60,
      "ui": {
        "component": "input",
        "placeholder": "timeout in seconds"
      }
    },
    {
      "id": "jsonData.tlsSkipVerify",
      "key": "tlsSkipVerify",
      "label": "Skip TLS Verify",
      "description": "Skip TLS certificate verification.",
      "valueType": "boolean",
      "target": "jsonData",
      "ui": {
        "component": "switch"
      }
    },
    {
      "id": "jsonData.tlsAuthWithCACert",
      "key": "tlsAuthWithCACert",
      "label": "With CA Cert",
      "description": "Needed for verifying self-signed TLS Certs.",
      "valueType": "boolean",
      "target": "jsonData",
      "ui": {
        "component": "switch"
      }
    },
    {
      "id": "secureJsonData.tlsCACert",
      "key": "tlsCACert",
      "label": "CA Cert",
      "description": "PEM-encoded CA certificate.",
      "valueType": "string",
      "target": "secureJsonData",
      "dependsOn": "jsonData.tlsAuthWithCACert == true",
      "ui": {
        "component": "textarea",
        "rows": 7
      }
    },
    {
      "id": "jsonData.tlsAuth",
      "key": "tlsAuth",
      "label": "TLS Client Auth",
      "description": "Enable TLS client certificate authentication.",
      "valueType": "boolean",
      "target": "jsonData",
      "ui": {
        "component": "switch"
      }
    },
    {
      "id": "jsonData.serverName",
      "key": "serverName",
      "label": "Server Name",
      "description": "Server name for TLS certificate verification.",
      "valueType": "string",
      "semanticType": "hostname",
      "target": "jsonData",
      "dependsOn": "jsonData.tlsAuth == true",
      "ui": {
        "component": "input",
        "placeholder": "domain.example.com"
      }
    },
    {
      "id": "secureJsonData.tlsClientCert",
      "key": "tlsClientCert",
      "label": "Client Cert",
      "description": "PEM-encoded client certificate.",
      "valueType": "string",
      "target": "secureJsonData",
      "dependsOn": "jsonData.tlsAuth == true",
      "ui": {
        "component": "textarea",
        "rows": 7
      }
    },
    {
      "id": "secureJsonData.tlsClientKey",
      "key": "tlsClientKey",
      "label": "Client Key",
      "description": "PEM-encoded client private key.",
      "valueType": "string",
      "semanticType": "token",
      "target": "secureJsonData",
      "dependsOn": "jsonData.tlsAuth == true",
      "ui": {
        "component": "textarea",
        "rows": 7
      }
    },
    {
      "id": "jsonData.proxy_type",
      "key": "proxy_type",
      "label": "Proxy",
      "description": "Proxy type for outgoing requests.",
      "valueType": "string",
      "target": "jsonData",
      "defaultValue": "env",
      "validations": [
        {
          "type": "allowedValues",
          "values": [
            "env",
            "url",
            "none"
          ]
        }
      ],
      "ui": {
        "component": "radio",
        "options": [
          {
            "label": "Environment",
            "value": "env"
