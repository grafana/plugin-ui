{
    "$schema": "../schema.json",
    "schemaVersion": "v1",
    "pluginType": "grafana-drone-datasource",
    "pluginName": "Drone",
    "docURL": "https://grafana.com/docs/plugins/grafana-drone-datasource",
    "fields": [
        {
            "id": "jsonData.variables.url",
            "key": "url",
            "label": "URL",
            "description": "The URL of the Drone server, including `https://` and without trailing `/`.",
            "valueType": "string",
            "semanticType": "url",
            "target": "jsonData",
            "section": "variables",
            "required": true,
            "ui": {
                "placeholder": "https://drone.example.com"
            }
        },
        {
            "id": "secureJsonData.drone.token",
            "key": "drone.token",
            "label": "Token",
            "description": "Drone API token. You can find your API token under <YOUR_DRONE_URL>/account.",
            "valueType": "string",
            "target": "secureJsonData",
            "semanticType": "token",
            "required": true,
            "ui": {
                "placeholder": "Token value"
            }
        }
    ],
    "groups": [
        {
            "id": "connection",
            "title": "Connection",
            "description": "Provide information to connect to the data source.",
            "fieldRefs": [
                "jsonData.variables.url"
            ]
        },
        {
            "id": "auth",
            "title": "Authentication",
            "description": "Drone API token.",
            "fieldRefs": [
                "secureJsonData.drone.token"
            ]
        }
    ]
}
