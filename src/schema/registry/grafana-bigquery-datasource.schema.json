      "id": "auth",
      "title": "Authentication",
      "fieldRefs": [
        "jsonData.authenticationType",
        "virtual.jwtUpload",
        "jsonData.defaultProject",
        "jsonData.clientEmail",
        "jsonData.tokenUri",
        "virtual.privateKeyMode",
        "secureJsonData.privateKey",
        "jsonData.privateKeyPath",
        "jsonData.defaultProjectNonJwt"
      ]
    },
    {
      "id": "impersonation",
      "title": "Service account impersonation",
      "optional": true,
      "fieldRefs": [
        "jsonData.usingImpersonation",
        "jsonData.serviceAccountToImpersonate"
      ]
    },
    {
      "id": "additional",
      "title": "Additional settings",
      "optional": true,
      "fieldRefs": [
        "jsonData.processingLocation",
        "jsonData.serviceEndpoint",
        "jsonData.MaxBytesBilled",
        "jsonData.queryPriority",
        "jsonData.flatRateProject",
        "jsonData.enableSecureSocksProxy"
      ]
    }
  ]
}
