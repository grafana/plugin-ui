{
  "$schema": "../schema.json",
  "schemaVersion": "v1",
  "pluginType": "grafana-gitlab-datasource",
  "pluginName": "GitLab",
  "fields": [
    {
      "id": "root.url",
      "key": "url",
      "label": "URL",
      "description": "GitLab instance URL. Leave blank for gitlab.com.",
      "valueType": "string",
      "semanticType": "url",
      "target": "root",
      "required": true,
      "ui": {
        "component": "input",
        "placeholder": "Default: https://gitlab.com"
      }
    },
    {
      "id": "jsonData.pageLimit",
      "key": "pageLimit",
      "label": "Page Limit",
      "description": "Maximum number of pages to fetch per request.",
      "valueType": "number",
      "target": "jsonData"
    },
    {
      "id": "jsonData.enableSecureSocksProxy",
      "key": "enableSecureSocksProxy",
      "label": "Secure Socks Proxy",
      "description": "Enable secure SOCKS proxy.",
      "valueType": "boolean",
      "target": "jsonData",
      "ui": {
        "component": "switch"
      }
    },
    {
      "id": "secureJsonData.accessToken",
      "key": "accessToken",
      "label": "Personal Access Token",
      "description": "GitLab personal access token with read_api scope.",
      "valueType": "string",
      "target": "secureJsonData",
      "required": true,
      "semanticType": "token"
    }
  ],
  "groups": [
    {
      "id": "connection",
      "title": "Connection",
      "fieldRefs": [
        "root.url"
      ]
    },
    {
      "id": "auth",
      "title": "Authentication",
      "fieldRefs": [
        "secureJsonData.accessToken"
      ]
    },
    {
      "id": "settings",
      "title": "Settings",
      "fieldRefs": [
        "jsonData.pageLimit",
        "jsonData.enableSecureSocksProxy"
      ]
    }
  ]
}
