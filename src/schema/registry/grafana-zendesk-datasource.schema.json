{
  "$schema": "../schema.json",
  "schemaVersion": "v1",
  "pluginType": "grafana-zendesk-datasource",
  "pluginName": "Zendesk",
  "docURL": "https://grafana.com/docs/plugins/grafana-zendesk-datasource",
  "fields": [
    {
      "id": "jsonData.variables.subdomain",
      "key": "subdomain",
      "label": "Subdomain",
      "description": "If your Zendesk URL is \"grafana.zendesk.com\", the subdomain would be \"grafana\".",
      "valueType": "string",
      "target": "jsonData",
      "section": "variables",
      "required": true,
      "ui": {
        "placeholder": ""
      }
    },
    {
      "id": "jsonData.services.zendesk.auth.username",
      "key": "services.zendesk.auth.username",
      "label": "Email",
      "description": "Email address used to login to Zendesk.",
      "valueType": "string",
      "target": "jsonData",
      "required": true,
      "ui": {
        "placeholder": "Email"
      }
    },
    {
      "id": "secureJsonData.zendesk.password",
      "key": "zendesk.password",
      "label": "API Token",
      "description": "API Token generated from Zendesk.",
      "valueType": "string",
      "target": "secureJsonData",
      "semanticType": "token",
      "required": true,
      "ui": {
        "placeholder": "API Token"
      }
    }
  ],
  "groups": [
    {
      "id": "connection",
      "title": "Connection",
      "description": "Provide information to connect to the data source.",
      "fieldRefs": [
        "jsonData.variables.subdomain"
      ]
    },
    {
      "id": "auth",
      "title": "Authentication",
      "description": "Basic Auth — Zendesk email and API token.",
      "fieldRefs": [
        "jsonData.services.zendesk.auth.username",
        "secureJsonData.zendesk.password"
      ]
    }
  ]
}
