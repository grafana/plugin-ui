{
  "name": "@grafana/plugin-ui",
  "version": "0.17.2",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/grafana/plugin-ui.git"
  },
  "license": "Apache-2.0",
  "author": "Grafana Labs",
  "type": "module",
  "main": "dist/cjs/index.cjs",
  "module": "dist/esm/index.js",
  "types": "dist/cjs/index.d.cts",
  "typesVersions": {
    "*": {
      "test": [
        "dist/cjs/test-utils.d.cts"
      ]
    }
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.cts",
        "default": "./dist/cjs/index.cjs"
      }
    },
    "./test": {
      "import": {
        "types": "./dist/esm/test-utils.d.ts",
        "default": "./dist/esm/test-utils.js"
      },
      "require": {
        "types": "./dist/cjs/test-utils.d.cts",
        "default": "./dist/cjs/test-utils.cjs"
      }
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p ./tsconfig.build.json && rollup -c rollup.config.ts --configPlugin esbuild",
    "dev": "tsc -p ./tsconfig.build.json && rollup -c rollup.config.ts --configPlugin esbuild -w",
    "clean": "rm -rf ./dist ./compiled ./storybook-static",
    "test": "jest --watch",
    "test:ci": "jest --ci",
    "spellcheck": "cspell -c cspell.config.json \"**/*.{ts,tsx,js,md,mdx,yml,yaml,json,scss,css}\"",
    "storybook": "storybook dev",
    "storybook:build": "storybook build",
    "lint": "eslint --cache --ignore-path ./.gitignore --ext .js,.jsx,.ts,.tsx .",
    "lint:fix": "yarn run lint --fix",
    "typecheck": "tsc",
    "verify-types": "attw --pack .",
    "verify-packagejson": "yarn publint .",
    "sanity-check": "yarn clean && yarn spellcheck && yarn lint && yarn typecheck && yarn test:ci && yarn build && yarn verify-types && yarn verify-packagejson && yarn storybook:build && yarn clean"
  },
  "dependencies": {
    "@emotion/css": "11.13.5",
    "@hello-pangea/dnd": "17.0.0",
    "@marcbachmann/cel-js": "7.6.1",
    "@react-awesome-query-builder/ui": "6.6.15",
    "lodash": "4.18.1",
    "prismjs": "1.30.0",
    "react-calendar": "4.8.0",
    "react-popper-tooltip": "4.4.2",
    "react-use": "17.6.1",
    "react-virtualized-auto-sizer": "1.0.26",
    "sql-formatter": "15.8.2",
    "uuid": "14.0.1"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.5",
    "@grafana/data": "13.1.0",
    "@grafana/e2e-selectors": "13.1.0",
    "@grafana/eslint-config": "8.2.0",
    "@grafana/runtime": "13.1.0",
    "@grafana/tsconfig": "2.2.0",
    "@grafana/ui": "13.1.0",
    "@rollup/plugin-commonjs": "29.0.3",
    "@rollup/plugin-json": "6.1.0",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@storybook/addon-docs": "10.5.0",
    "@storybook/addon-links": "10.5.0",
    "@storybook/addon-webpack5-compiler-swc": "4.0.3",
    "@storybook/react-webpack5": "10.5.0",
    "@stylistic/eslint-plugin-ts": "4.4.1",
    "@swc/core": "1.15.43",
    "@swc/jest": "0.2.39",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/chance": "1.1.8",
    "@types/jest": "30.0.0",
    "@types/lodash": "4.17.24",
    "@types/memoize-one": "5.1.2",
    "@types/node": "25.9.5",
    "@types/prismjs": "1.26.6",
    "@types/react": "18.3.31",
    "@types/react-calendar": "3.9.0",
    "@types/testing-library__jest-dom": "6.0.0",
    "@typescript-eslint/eslint-plugin": "8.63.0",
    "@typescript-eslint/parser": "8.63.0",
    "chance": "1.1.13",
    "copyfiles": "2.4.1",
    "cspell": "10.0.1",
    "esbuild": "0.28.1",
    "eslint": "8.57.1",
    "eslint-config-prettier": "8.10.2",
    "eslint-plugin-jsdoc": "46.10.1",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "4.6.2",
    "fast-glob": "3.3.3",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "jest-fetch-mock": "3.2.0",
    "lefthook": "2.1.10",
    "mockdate": "3.0.5",
    "prettier": "3.9.5",
    "publint": "0.3.21",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-select-event": "5.5.1",
    "rollup": "4.59.0",
    "rollup-plugin-dts": "6.4.1",
    "rollup-plugin-esbuild": "6.2.1",
    "rollup-plugin-node-externals": "9.0.1",
    "rxjs": "7.8.2",
    "storybook": "10.5.0",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "@grafana/data": "^13.0.0",
    "@grafana/e2e-selectors": "^13.0.0",
    "@grafana/runtime": "^13.0.0",
    "@grafana/ui": "^13.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24",
    "yarn": ">=4.16.0"
  },
  "packageManager": "yarn@4.17.1"
}
