{
  "$schema": "../schema.json",
  "schemaVersion": "v1",
  "pluginType": "grafana-salesforce-datasource",
  "pluginName": "Salesforce",
  "docURL": "https://grafana.com/docs/plugins/grafana-salesforce-datasource/latest/configure/",
  "fields": [
    {
      "id": "jsonData.authType",
      "key": "authType",
      "label": "Authentication",
      "description": "Salesforce authentication method.",
      "valueType": "string",
      "target": "jsonData",
      "required": true,
      "defaultValue": "user",
      "validations": [
        {
          "type": "allowedValues",
          "values": [
            "user",
            "jwt"
          ]
        }
      ],
      "ui": {
        "component": "radio",
        "options": [
          {
            "label": "Credentials",
            "value": "user"
          },
          {
            "label": "JWT",
            "value": "jwt"
          }
        ]
      }
    },
    {
      "id": "jsonData.user",
      "key": "user",
      "label": "User Name",
      "description": "Salesforce username.",
      "valueType": "string",
      "target": "jsonData",
      "required": true,
      "ui": {
        "placeholder": "Salesforce User"
      }
    },
    {
      "id": "secureJsonData.password",
      "key": "password",
      "label": "Password",
      "description": "Salesforce password.",
      "valueType": "string",
      "target": "secureJsonData",
      "semanticType": "password",
      "dependsOn": "jsonData.authType == 'user'",
      "requiredWhen": "jsonData.authType == 'user'",
      "ui": {
        "placeholder": "Salesforce Password"
      }
    },
    {
      "id": "secureJsonData.securityToken",
      "key": "securityToken",
      "label": "Security Token",
      "description": "Salesforce security token appended to password.",
      "valueType": "string",
      "target": "secureJsonData",
      "semanticType": "token",
      "dependsOn": "jsonData.authType == 'user'",
      "ui": {
        "placeholder": "Salesforce Security Token"
      }
    },
    {
      "id": "secureJsonData.clientID",
      "key": "clientID",
      "label": "Consumer Key",
      "description": "Salesforce Connected App consumer key.",
      "valueType": "string",
      "target": "secureJsonData",
      "semanticType": "token",
      "required": true,
      "ui": {
        "placeholder": "Connected App Consumer Key"
      }
    },
    {
      "id": "secureJsonData.clientSecret",
      "key": "clientSecret",
      "label": "Consumer Secret",
      "description": "Salesforce Connected App consumer secret.",
      "valueType": "string",
      "target": "secureJsonData",
      "semanticType": "token",
      "dependsOn": "jsonData.authType == 'user'",
      "requiredWhen": "jsonData.authType == 'user'",
      "ui": {
        "placeholder": "Connected App Consumer Secret"
      }
    },
    {
      "id": "secureJsonData.cert",
      "key": "cert",
      "label": "Certificate",
      "description": "X.509 certificate for JWT authentication (PEM format).",
      "valueType": "string",
      "target": "secureJsonData",
      "dependsOn": "jsonData.authType == 'jwt'",
      "requiredWhen": "jsonData.authType == 'jwt'",
      "ui": {
        "component": "textarea",
        "rows": 7,
        "placeholder": "-----BEGIN CERTIFICATE-----"
      }
    },
    {
      "id": "secureJsonData.privateKey",
      "key": "privateKey",
      "label": "Private Key",
      "description": "Private key for JWT signing (PEM format).",
      "valueType": "string",
      "target": "secureJsonData",
      "semanticType": "token",
      "dependsOn": "jsonData.authType == 'jwt'",
      "requiredWhen": "jsonData.authType == 'jwt'",
      "ui": {
        "component": "textarea",
        "rows": 7,
        "placeholder": "-----BEGIN PRIVATE KEY-----"
      }
    },
    {
      "id": "environment",
      "key": "environment",
      "label": "Environment",
      "description": "Salesforce environment to connect to.",
      "valueType": "string",
      "kind": "virtual",
      "defaultValue": "production",
      "ui": {
        "component": "select",
        "options": [
          {
            "label": "Production",
            "value": "production"
          },
          {
            "label": "Sandbox",
            "value": "sandbox"
          }
        ]
      },
      "storage": {
        "type": "computed",
        "read": "jsonData.tokenUrl == 'https://test.salesforce.com' ? 'sandbox' : (jsonData.sandbox == true ? 'sandbox' : 'production')"
      },
      "effects": [
        {
          "when": "value == 'production'",
          "set": {
            "jsonData.tokenUrl": "https://login.salesforce.com",
            "jsonData.sandbox": false
          }
        },
        {
          "when": "value == 'sandbox'",
          "set": {
            "jsonData.tokenUrl": "https://test.salesforce.com",
            "jsonData.sandbox": true
          }
        }
      ]
    },
    {
      "id": "jsonData.tokenUrl",
      "key": "tokenUrl",
      "label": "Token URL",
      "description": "Salesforce OAuth token endpoint.",
      "valueType": "string",
      "semanticType": "url",
      "target": "jsonData",
      "tags": [
        "managed-by:environment"
      ]
    },
    {
      "id": "jsonData.sandbox",
      "key": "sandbox",
      "label": "Sandbox",
      "description": "Legacy sandbox toggle (managed by Environment selector).",
      "valueType": "boolean",
      "target": "jsonData",
      "tags": [
        "managed-by:environment"
      ]
    },
    {
      "id": "jsonData.enableSecureSocksProxy",
      "key": "enableSecureSocksProxy",
      "label": "Enable Secure Socks Proxy",
      "description": "Enable proxying the datasource connection through the secure socks proxy to a different network.",
      "valueType": "boolean",
      "target": "jsonData",
      "ui": {
        "component": "switch"
      }
    }
  ],
  "groups": [
    {
      "id": "connection",
      "title": "Connection Settings",
      "fieldRefs": [
        "jsonData.authType",
        "jsonData.user",
        "secureJsonData.password",
        "secureJsonData.securityToken",
        "secureJsonData.clientID",
        "secureJsonData.clientSecret",
        "secureJsonData.cert",
        "secureJsonData.privateKey"
      ]
    },
    {
      "id": "settings",
      "title": "Optional Settings",
      "fieldRefs": [
        "environment",
        "jsonData.enableSecureSocksProxy"
      ]
    }
  ]
}
