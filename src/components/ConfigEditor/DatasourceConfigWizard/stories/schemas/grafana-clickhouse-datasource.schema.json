{
  "$schema": "./../../../../../datasource/schema/schema.json",
  "schemaVersion": "v1",
  "pluginType": "grafana-clickhouse-datasource",
  "pluginName": "ClickHouse",
  "docURL": "https://grafana.com/grafana/plugins/grafana-clickhouse-datasource/",
  "fields": [
    {
      "id": "jsonData.host",
      "key": "host",
      "label": "Server address",
      "description": "ClickHouse host address.",
      "valueType": "string",
      "target": "jsonData",
      "required": true,
      "storage": {
        "type": "computed",
        "read": "jsonData.server"
      },
      "ui": {
        "component": "input",
        "placeholder": "Server address"
      }
    },
    {
      "id": "jsonData.port",
      "key": "port",
      "label": "Server port",
      "description": "ClickHouse server port.",
      "valueType": "number",
      "target": "jsonData",
      "required": true,
      "defaultValue": 9000,
      "overrides": [
        {
          "when": "jsonData.protocol == 'native'",
          "description": "ClickHouse server port (default for native: 9000).",
          "defaultValue": 9000
        },
        {
          "when": "jsonData.protocol == 'http'",
          "description": "ClickHouse server port (default for http: 8123).",
          "defaultValue": 8123
        }
      ]
    },
    {
      "id": "jsonData.protocol",
      "key": "protocol",
      "label": "Protocol",
      "description": "Native or HTTP for server protocol. Native uses ClickHouse's binary TCP interface for better performance.",
      "valueType": "string",
      "target": "jsonData",
      "required": true,
      "defaultValue": "native",
      "validations": [
        {
          "type": "allowedValues",
          "values": [
            "native",
            "http"
          ]
        }
      ],
      "ui": {
        "component": "radio",
        "options": [
          {
            "label": "Native",
            "value": "native"
          },
          {
            "label": "HTTP",
            "value": "http"
          }
        ]
      }
    },
    {
      "id": "jsonData.username",
      "key": "username",
      "label": "Username",
      "description": "ClickHouse username. We recommend configuring a read-only user.",
      "valueType": "string",
      "target": "jsonData",
      "ui": {
        "component": "input",
        "placeholder": "default"
      }
    },
    {
      "id": "jsonData.version",
      "key": "version",
      "label": "Plugin version",
      "description": "Plugin version this config was saved with.",
      "valueType": "string",
      "target": "jsonData"
    },
    {
      "id": "jsonData.secure",
      "key": "secure",
      "label": "Secure connection",
      "description": "Enable when your ClickHouse server uses TLS. Update the port to a TLS-enabled port when enabled.",
      "valueType": "boolean",
      "target": "jsonData",
      "ui": {
        "component": "switch"
      }
    },
    {
      "id": "jsonData.path",
      "key": "path",
      "label": "HTTP URL Path",
      "description": "Additional URL path for HTTP requests. Default: /",
      "valueType": "string",
      "target": "jsonData",
      "dependsOn": "jsonData.protocol == 'http'",
      "ui": {
        "component": "input",
        "placeholder": "additional-path"
      }
    },
    {
      "id": "jsonData.tlsSkipVerify",
      "key": "tlsSkipVerify",
      "label": "Skip TLS Verify",
      "description": "Skip TLS certificate verification.",
      "valueType": "boolean",
      "target": "jsonData",
      "ui": {
        "component": "switch"
      }
    },
    {
      "id": "jsonData.tlsAuth",
      "key": "tlsAuth",
      "label": "TLS Client Auth",
      "description": "Enable TLS client certificate authentication.",
      "valueType": "boolean",
      "target": "jsonData",
      "ui": {
        "component": "switch"
      }
    },
    {
      "id": "jsonData.tlsAuthWithCACert",
      "key": "tlsAuthWithCACert",
      "label": "With CA Cert",
      "description": "Provide a CA certificate for TLS verification.",
      "valueType": "boolean",
      "target": "jsonData",
      "ui": {
        "component": "switch"
      }
    },
    {
      "id": "jsonData.defaultDatabase",
      "key": "defaultDatabase",
      "label": "Default database",
      "description": "The default database used by the query builder.",
      "valueType": "string",
      "target": "jsonData",
      "ui": {
        "component": "input",
        "placeholder": "default"
      }
    },
    {
      "id": "jsonData.defaultTable",
      "key": "defaultTable",
      "label": "Default table",
      "description": "The default table used by the query builder.",
      "valueType": "string",
      "target": "jsonData",
      "ui": {
        "component": "input",
        "placeholder": "table"
      }
    },
    {
      "id": "jsonData.connMaxLifetime",
      "key": "connMaxLifetime",
      "label": "Connection Max Lifetime (minutes)",
      "description": "Maximum lifetime of a connection in minutes.",
      "valueType": "string",
      "target": "jsonData",
      "ui": {
        "component": "input",
        "placeholder": "5"
      }
    },
    {
      "id": "jsonData.dialTimeout",
      "key": "dialTimeout",
      "label": "Dial Timeout (seconds)",
      "description": "Timeout in seconds for establishing a connection. Default: 10.",
      "valueType": "string",
      "target": "jsonData",
      "defaultValue": "10",
      "ui": {
        "component": "input",
        "placeholder": "10"
      }
    },
    {
      "id": "jsonData.maxIdleConns",
      "key": "maxIdleConns",
      "label": "Max Idle Connections",
      "description": "Maximum number of idle connections.",
      "valueType": "string",
      "target": "jsonData",
      "ui": {
        "component": "input",
        "placeholder": "25"
      }
    },
    {
      "id": "jsonData.maxOpenConns",
      "key": "maxOpenConns",
      "label": "Max Open Connections",
      "description": "Maximum number of open connections.",
      "valueType": "string",
      "target": "jsonData",
      "ui": {
        "component": "input",
        "placeholder": "50"
      }
    },
    {
      "id": "jsonData.queryTimeout",
      "key": "queryTimeout",
      "label": "Query Timeout (seconds)",
      "description": "Timeout in seconds for read queries. Default: 60.",
      "valueType": "string",
      "target": "jsonData",
      "defaultValue": "60",
      "ui": {
        "component": "input",
        "placeholder": "60"
      }
    },
    {
      "id": "jsonData.validateSql",
      "key": "validateSql",
      "label": "Validate SQL",
      "description": "Validate SQL in the editor.",
      "valueType": "boolean",
      "target": "jsonData",
      "ui": {
        "component": "switch"
      }
    },
    {
      "id": "jsonData.forwardGrafanaHeaders",
      "key": "forwardGrafanaHeaders",
      "label": "Forward Grafana HTTP Headers",
      "description": "Forward Grafana HTTP Headers to datasource.",
      "valueType": "boolean",
      "target": "jsonData",
      "dependsOn": "jsonData.protocol == 'http'",
      "ui": {
        "component": "switch"
      }
    },
    {
      "id": "jsonData.enableRowLimit",
      "key": "enableRowLimit",
      "label": "Enable row limit",
      "description": "Enable using the Grafana row limit setting to limit the number of rows returned from ClickHouse. Only supported for Grafana >= 11.0.0.",
      "valueType": "boolean",
      "target": "jsonData",
      "ui": {
        "component": "switch"
      }
    },
    {
      "id": "secureJsonData.password",
      "key": "password",
      "label": "Password",
      "description": "ClickHouse user password.",
      "valueType": "string",
      "semanticType": "password",
      "target": "secureJsonData"
    },
    {
      "id": "secureJsonData.tlsCACert",
      "key": "tlsCACert",
      "label": "CA Cert",
      "description": "PEM-encoded CA certificate.",
      "valueType": "string",
      "target": "secureJsonData",
      "dependsOn": "jsonData.tlsAuthWithCACert == true",
      "ui": {
        "component": "textarea",
        "rows": 7
      }
    },
    {
      "id": "secureJsonData.tlsClientCert",
      "key": "tlsClientCert",
      "label": "Client Cert",
      "description": "PEM-encoded client certificate.",
      "valueType": "string",
      "target": "secureJsonData",
      "dependsOn": "jsonData.tlsAuth == true",
      "ui": {
        "component": "textarea",
        "rows": 7
      }
    },
    {
      "id": "secureJsonData.tlsClientKey",
      "key": "tlsClientKey",
      "label": "Client Key",
      "description": "PEM-encoded client private key.",
      "valueType": "string",
      "semanticType": "token",
      "target": "secureJsonData",
      "dependsOn": "jsonData.tlsAuth == true",
      "ui": {
        "component": "textarea",
        "rows": 7
      }
    },
    {
      "id": "jsonData.logs.defaultDatabase",
      "key": "defaultDatabase",
      "label": "Default log database",
      "description": "The default database used by the logs query builder.",
      "valueType": "string",
      "target": "jsonData",
      "section": "logs",
      "ui": {
        "component": "input",
        "placeholder": "default"
      }
    },
    {
      "id": "jsonData.logs.defaultTable",
      "key": "defaultTable",
      "label": "Default log table",
      "description": "The default table used by the logs query builder.",
      "valueType": "string",
      "target": "jsonData",
      "section": "logs",
      "defaultValue": "otel_logs",
      "ui": {
        "component": "input",
        "placeholder": "otel_logs"
      }
    },
    {
      "id": "jsonData.logs.otelEnabled",
      "key": "otelEnabled",
      "label": "Use OTel",
      "description": "Enable OpenTelemetry schema versioning for log column mappings.",
      "valueType": "boolean",
      "target": "jsonData",
      "section": "logs",
      "ui": {
        "component": "switch"
      }
    },
    {
      "id": "jsonData.logs.otelVersion",
      "key": "otelVersion",
      "label": "OTel version",
      "description": "OpenTelemetry schema version for log columns. Select the version that matches your OTel ClickHouse exporter.",
      "valueType": "string",
      "target": "jsonData",
      "section": "logs",
      "defaultValue": "latest",
      "dependsOn": "jsonData.logs.otelEnabled == true",
      "validations": [
        {
          "type": "allowedValues",
          "values": [
            "latest",
            "1.29.0"
          ]
        }
      ],
      "ui": {
        "component": "select",
        "options": [
          {
            "label": "latest (1.2.9)",
            "value": "latest"
          },
          {
            "label": "1.2.9",
            "value": "1.29.0"
          }
        ]
      }
    },
    {
      "id": "jsonData.logs.filterTimeColumn",
      "key": "filterTimeColumn",
      "label": "Filter Time column",
      "description": "Column for time-based partition filtering (lower precision).",
